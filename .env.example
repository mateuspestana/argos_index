 ============================================
# Argos Index - Configurações
# ============================================
# Copie este arquivo para .env e ajuste conforme necessário
# cp .env.example .env
#
# No Windows, use: copy .env.example .env
# ============================================

# ============================================
# Banco de Dados
# ============================================
# Tipo de banco: sqlite ou mysql
ARGOS_DB_TYPE=sqlite

# SQLite (padrão - usado quando ARGOS_DB_TYPE=sqlite)
# Caminho relativo ou absoluto para o arquivo de banco
# Exemplos:
#   - Relativo: data/database.db
#   - Absoluto Linux/Mac: /home/user/argos/data/database.db
#   - Absoluto Windows: D:/ArgosData/database.db
ARGOS_SQLITE_DB_PATH=data/database.db

# MySQL (usado quando ARGOS_DB_TYPE=mysql)
ARGOS_MYSQL_HOST=localhost
ARGOS_MYSQL_PORT=3306
ARGOS_MYSQL_USER=argos
ARGOS_MYSQL_PASSWORD=g1s3@@2026
ARGOS_MYSQL_DATABASE=argos_index

# ============================================
# Diretório de Monitoramento
# ============================================
# Diretório onde o sistema monitora arquivos .ufdr
# Pode ser relativo ao projeto ou absoluto
# Exemplos:
#   - Relativo: ufdrs
#   - Absoluto Linux/Mac: /home/user/UFDRs
#   - Absoluto Windows: D:\UFDRs ou D:/UFDRs
ARGOS_WATCH_DIR=files_test

# URL remota (opcional - para monitoramento remoto)
# Deixe vazio se não usar
ARGOS_WATCH_URL=

# ============================================
# Configurações de Processamento
# ============================================
# Tamanho do batch para inserções no banco
ARGOS_BATCH_SIZE=1000

# Tamanho máximo do contexto extraído para regex hits
ARGOS_MAX_CONTEXT=500

# ============================================
# Configurações de Logging
# ============================================
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
ARGOS_LOG_LEVEL=INFO

# Caminho do arquivo de log (relativo ou absoluto)
# Exemplos:
#   - Relativo: logs/argos.log
#   - Absoluto: D:/ArgosData/logs/argos.log
ARGOS_LOG_FILE=logs/argos.log

# ============================================
# Diretórios do Sistema
# ============================================
# Estes diretórios são criados automaticamente se não existirem
# Podem ser relativos ao projeto ou absolutos

# Diretório de dados (padrão: data/)
ARGOS_DATA_DIR=data

# Diretório de logs (padrão: logs/)
ARGOS_LOGS_DIR=logs

# Diretório temporário para extração (padrão: temp/)
ARGOS_TEMP_DIR=temp

# ============================================
# Arquivo de Padrões Regex
# ============================================
# Caminho para o arquivo JSON com padrões regex
# Padrão: data/regex_patterns.json
ARGOS_REGEX_PATTERNS_FILE=data/regex_patterns.json